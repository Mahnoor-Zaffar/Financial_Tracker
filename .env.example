FLASK_APP=app.py
FLASK_ENV=development
APP_ENV=development
SECRET_KEY=change-this-in-production

# Leave DATABASE_URL empty for local SQLite (instance/finance_tracker.db)
DATABASE_URL=

# Set to true behind HTTPS in production
SESSION_COOKIE_SECURE=false
LOG_LEVEL=INFO

# Login abuse throttling
# Window and cooldown are in seconds.
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_LOGIN_COOLDOWN_SECONDS=900
AUTH_LOGIN_IP_LIMIT=10
AUTH_LOGIN_ACCOUNT_LIMIT=5

# Transaction list pagination defaults
TRANSACTIONS_PER_PAGE=20
MAX_TRANSACTIONS_PER_PAGE=100
